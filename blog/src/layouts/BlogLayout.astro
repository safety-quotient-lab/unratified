---
import LensToggle from '@main/components/lens/LensToggle.svelte';
import ThemeToggle from '@main/components/lens/ThemeToggle.svelte';
import { SITE_AUTHOR } from '@main/consts';
import '@main/styles/base.css';
import '@main/styles/lens.css';

interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
}

const {
  title,
  description = 'AI confabulation research, ICESCR ratification advocacy, and the intersection of artificial intelligence with economic rights. Seven confabulation types documented across 31 rounds of testing.',
  ogType = 'website',
} = Astro.props;

const siteOrigin = 'https://blog.unratified.org';
const mainSite = 'https://unratified.org';
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin);
const fullTitle = `${title} | blog.unratified.org`;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Unratified Blog',
  description: 'AI confabulation research, ICESCR ratification advocacy, and fair witness methodology. Documenting seven confabulation types across 31 rounds of empirical testing.',
  url: siteOrigin,
  publisher: {
    '@type': 'Organization',
    name: 'Safety Quotient Lab',
    url: 'https://github.com/safety-quotient-lab',
    founder: {
      '@type': 'Person',
      name: 'Kashif Shah',
      url: 'https://kashifshah.net',
    },
    knowsAbout: [
      'International Covenant on Economic, Social and Cultural Rights (ICESCR)',
      'Universal Declaration of Human Rights (UDHR)',
      'U.S. treaty ratification process',
      'AI economic impact analysis',
      'AI accuracy and confabulation patterns',
      'Fair witness methodology',
    ],
  },
  creator: [
    {
      '@type': 'SoftwareApplication',
      name: 'Claude',
      url: 'https://www.anthropic.com/claude',
      applicationCategory: 'Artificial Intelligence',
      provider: {
        '@type': 'Organization',
        name: 'Anthropic',
        url: 'https://www.anthropic.com',
      },
    },
    {
      '@type': 'Person',
      name: 'Kashif Shah',
      url: 'https://kashifshah.net',
    },
  ],
  isPartOf: {
    '@type': 'WebSite',
    name: 'Unratified',
    url: mainSite,
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fafafa" />
    <meta name="ai-generated" content="all" />

    <script is:inline>
      (function() {
        var t = localStorage.getItem('unratified-blog-theme');
        if (!t && window.matchMedia('(prefers-color-scheme: dark)').matches) {
          t = 'dark';
        }
        if (t === 'dark') {
          document.documentElement.setAttribute('data-theme', 'dark');
          var m = document.querySelector('meta[name="theme-color"]');
          if (m) m.setAttribute('content', '#002d38');
        }
      })();
    </script>

    <link rel="icon" type="image/png" href="/favicon.png?v=2" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=2" />
    <link rel="canonical" href={canonicalUrl.href} />
    <link rel="alternate" type="application/rss+xml" title="Unratified Blog RSS" href={`${siteOrigin}/rss.xml`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300;400;500;600;700&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300;400;500;600;700&display=swap" /></noscript>

    <meta name="author" content={SITE_AUTHOR} />
    <meta property="article:modified_time" content={new Date().toISOString()} />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:site_name" content="Unratified Blog" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={`${mainSite}/og-image`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Unratified Blog \u2014 AI confabulation taxonomy, ICESCR ratification advocacy, and fair witness methodology" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${mainSite}/og-image`} />
    <meta name="twitter:image:alt" content="Unratified Blog \u2014 AI confabulation taxonomy, ICESCR ratification advocacy, and fair witness methodology" />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <title>{fullTitle}</title>
  </head>
  <body data-lens="voter">
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <div class="review-banner" role="status">
      <p>
        <strong>AI-generated site.</strong>
        <a href="https://www.anthropic.com/claude" rel="noopener">Claude</a> built this entire site &mdash; analysis, copy, and code &mdash; under human direction.
        Content remains under review.
        <a href="https://github.com/safety-quotient-lab/unratified" rel="noopener">Suggest corrections on GitHub &rarr;</a>
      </p>
    </div>

    <header class="site-header">
      <nav aria-label="Main navigation">
        <a href="/" class="site-title">Unratified Blog</a>
        <ul class="nav-links">
          <li><a href="/">Posts</a></li>
          <li><a href="/rss.xml">RSS</a></li>
          <li><a href={mainSite} rel="noopener">Main Site &nearr;</a></li>
          <li><a href={`${mainSite}/action`} rel="noopener">Take Action &nearr;</a></li>
        </ul>
        <div class="nav-controls">
          <LensToggle client:load />
          <ThemeToggle client:load />
        </div>
      </nav>
    </header>

    <main id="main-content">
      <slot />
    </main>

    {ogType !== 'article' && (
      <div class="page-meta" role="contentinfo" aria-label="Page information">
        <p>By {SITE_AUTHOR} &middot; Last updated {new Date().toISOString().split('T')[0]}</p>
      </div>
    )}

    <footer class="site-footer">
      <div class="footer-grid">
        <div class="footer-col">
          <h4>Project</h4>
          <p><a href="https://github.com/safety-quotient-lab" rel="noopener">Safety Quotient Lab</a></p>
          <p>by <a href="https://kashifshah.net" rel="noopener">Kashif Shah</a></p>
          <p><a href="https://creativecommons.org/licenses/by-sa/4.0/" rel="noopener">CC BY-SA 4.0</a></p>
        </div>
        <div class="footer-col">
          <h4>Built With</h4>
          <p><a href="https://www.anthropic.com/claude" rel="noopener">Claude (Anthropic)</a></p>
          <p><a href="https://www.wolframalpha.com/" rel="noopener">Wolfram|Alpha</a></p>
          <p><a href="https://pages.cloudflare.com/" rel="noopener">Cloudflare</a></p>
        </div>
        <div class="footer-col">
          <h4>Links</h4>
          <p><a href={mainSite} rel="noopener">unratified.org</a></p>
          <p><a href="https://unratified.org/colophon" rel="noopener">Colophon</a></p>
          <p><a href="mailto:kashif&#64;kashifshah.net">Contact</a></p>
          <p><a href="https://github.com/safety-quotient-lab/unratified" rel="noopener">GitHub &nearr;</a></p>
        </div>
      </div>
      <p class="footer-note">
        Human Rights; Nothing More, Nothing Less.
      </p>
    </footer>
  </body>
</html>
