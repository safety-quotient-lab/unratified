---
import BlogLayout from './BlogLayout.astro';
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import { fileURLToPath } from 'node:url';

interface Author {
  human: { name: string; url: string };
  tool: { name: string; url: string };
  model: { name: string; url: string }[];
  agent: { name: string; projectUrl: string; sections?: string[] }[];
}

interface Revision {
  hash: string;
  date: string;
  subject: string;
}

interface Review {
  reviewer: string;
  date: Date;
  status: 'pass' | 'pass-with-notes' | 'fail' | 'revise';
  findings?: string;
  findingsUrl?: string;
}

interface Props {
  title: string;
  summary: string;
  publishedDate: Date;
  updatedDate?: Date;
  author: Author;
  tags: string[];
  slug: string;
  reviewStatus?: string;
  reviews?: Review[];
}

const { title, summary, publishedDate, updatedDate, author, tags, slug, reviewStatus, reviews = [] } = Astro.props;

// Load git-backed revision history generated by scripts/generate-revisions.js
const layoutDir = fileURLToPath(new URL('.', import.meta.url));
const revisionFile = join(layoutDir, '..', 'data', 'revisions', `${slug}.json`);
let revisions: Revision[] = [];
try {
  revisions = JSON.parse(readFileSync(revisionFile, 'utf8'));
} catch {
  // Revision data not yet generated — degrade gracefully
}

const mainSite = 'https://unratified.org';
const repoBase = 'https://github.com/safety-quotient-lab/unratified';
const sourceUrl = `${repoBase}/blob/main/blog/src/content/posts/${slug}.md`;
const historyUrl = `${repoBase}/commits/main/blog/src/content/posts/${slug}.md`;

function formatDate(date: Date): string {
  return date.toLocaleString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    hour: 'numeric',
    minute: '2-digit',
    timeZoneName: 'short',
    timeZone: 'America/New_York',
  });
}

// Estimate reading time from slot content (rough: 200 words/min)
const content = await Astro.slots.render('default');
const wordCount = content.replace(/<[^>]*>/g, '').split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));
---

<BlogLayout title={title} description={summary} ogType="article">
  <article class="blog-post">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Blog</a></li>
        <li aria-current="page">{title}</li>
      </ol>
    </nav>

    <header class="post-header">
      <h1>{title}</h1>
      <div class="post-meta">
        <span class="date-label">Created</span>
        <time datetime={publishedDate.toISOString()}>
          {formatDate(publishedDate)}
        </time>
        {updatedDate && (
          <span class="updated">
            &middot; <span class="date-label">Updated</span>
            <time datetime={updatedDate.toISOString()}>
              {formatDate(updatedDate)}
            </time>
          </span>
        )}
        <span class="author">&middot;
          <a href={author.human.url} rel="noopener">{author.human.name}</a>
          &middot;
          <a href={author.tool.url} rel="noopener">{author.tool.name}</a>
          &middot;
          {author.model.map((m, i) => (
            <>{i > 0 && <>&middot;</>}<a href={m.url} rel="noopener">{m.name}</a></>
          ))}
          &middot;
          {author.agent.map((a, i) => (
            <>{i > 0 && <>&middot;</>}<a href={a.projectUrl} rel="noopener">{a.name}</a></>
          ))}
        </span>
        <span class="reading-time">&middot; {readingTime} min read</span>
        {reviewStatus === 'unreviewed' && (
          <span class="review-badge">&middot; Pre-Review</span>
        )}
        {reviewStatus === 'ai-reviewed' && (
          <span class="review-badge ai-reviewed">&middot; AI-Reviewed</span>
        )}
      </div>
      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map(tag => (
            <a href={`/tags/${tag}`} class="tag">#{tag}</a>
          ))}
        </div>
      )}
    </header>

    <div class="post-content">
      <slot />
    </div>

    <footer class="post-footer">
      <p>
        <a href="/">← Back to all posts</a>
        &middot;
        <a href={`${mainSite}/action`} rel="noopener">Take Action on ICESCR →</a>
      </p>
      <p class="post-provenance">
        <a href={sourceUrl} rel="noopener">View source</a>
        &middot;
        <a href={historyUrl} rel="noopener">Full git history</a>
      </p>

      {reviews.length > 0 && (
        <details class="review-audit" open>
          <summary class="revision-summary">
            Review history
            <span class="revision-count">({reviews.length} review{reviews.length !== 1 ? 's' : ''})</span>
          </summary>
          <ol class="revision-list">
            {reviews.map(rev => (
              <li class="revision-entry">
                <span class={`review-status-badge status-${rev.status}`}>{rev.status}</span>
                <strong>{rev.reviewer}</strong>
                <time datetime={new Date(rev.date).toISOString()}>
                  {new Date(rev.date).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                    timeZone: 'America/New_York',
                  })}
                </time>
                {rev.findings && <span class="review-findings">&mdash; {rev.findings}</span>}
                {rev.findingsUrl && <a href={rev.findingsUrl} rel="noopener" class="review-link">details →</a>}
              </li>
            ))}
          </ol>
        </details>
      )}

      {revisions.length > 0 && (
        <details class="revision-history">
          <summary class="revision-summary">
            Revision history
            <span class="revision-count">({revisions.length} commit{revisions.length !== 1 ? 's' : ''})</span>
          </summary>
          <ol class="revision-list">
            {revisions.map(rev => (
              <li class="revision-entry">
                <time datetime={rev.date}>
                  {new Date(rev.date).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                    timeZone: 'America/New_York',
                  })}
                </time>
                <a
                  href={`${repoBase}/commit/${rev.hash}`}
                  rel="noopener"
                  class="revision-subject"
                >
                  {rev.subject}
                </a>
              </li>
            ))}
          </ol>
        </details>
      )}

      <p class="post-provenance">
        AI-generated content &mdash;
        <a href="https://www.anthropic.com/claude" rel="noopener">Claude (Anthropic)</a>
        under human direction.
      </p>
    </footer>
  </article>
</BlogLayout>

<style>
  .blog-post {
    max-width: var(--max-width-content);
    margin: 0 auto;
  }

  .breadcrumb ol {
    list-style: none;
    display: flex;
    gap: var(--space-sm);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
  }

  .breadcrumb li + li::before {
    content: '/';
    margin-right: var(--space-sm);
    color: var(--color-border);
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .post-header {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .post-meta {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .tag {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-accent);
    text-decoration: none;
    padding: var(--space-xs) var(--space-sm);
    border: 1px solid var(--color-border);
    border-radius: 3px;
  }

  .tag:hover {
    background: var(--color-surface-alt);
  }

  .post-content {
    line-height: 1.7;
  }

  .post-footer {
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
    font-family: var(--font-heading);
    font-size: 0.875rem;
  }

  .post-provenance {
    margin-top: var(--space-sm);
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .post-provenance a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .post-provenance a:hover {
    color: var(--color-accent);
  }

  .author a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .author a:hover {
    color: var(--color-accent);
  }

  .date-label {
    font-weight: 600;
  }

  .review-badge {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    color: #b58900;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .review-badge.ai-reviewed {
    color: #268bd2;
  }

  .review-audit {
    margin-top: var(--space-md);
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .review-status-badge {
    font-family: var(--font-heading);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    padding: 0.1rem 0.4rem;
    border-radius: 2px;
    margin-right: var(--space-xs);
  }

  .status-pass { color: #859900; border: 1px solid #85990044; }
  .status-pass-with-notes { color: #b58900; border: 1px solid #b5890044; }
  .status-fail { color: #dc322f; border: 1px solid #dc322f44; }
  .status-revise { color: #cb4b16; border: 1px solid #cb4b1644; }

  .review-findings {
    color: var(--color-text-muted);
  }

  .review-link {
    color: var(--color-accent);
    text-decoration: none;
    margin-left: var(--space-xs);
  }

  .review-link:hover {
    text-decoration: underline;
  }

  .revision-history {
    margin-top: var(--space-md);
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .revision-summary {
    cursor: pointer;
    font-family: var(--font-heading);
    color: var(--color-text-muted);
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .revision-summary::-webkit-details-marker {
    display: none;
  }

  .revision-summary::before {
    content: '▸';
    font-size: 0.6rem;
    transition: transform 0.15s;
  }

  details[open] .revision-summary::before {
    transform: rotate(90deg);
  }

  .revision-summary:hover {
    color: var(--color-accent);
  }

  .revision-count {
    color: var(--color-text-muted);
    opacity: 0.7;
  }

  .revision-list {
    list-style: none;
    margin: var(--space-sm) 0 0 var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    border-left: 1px solid var(--color-border);
    padding-left: var(--space-md);
  }

  .revision-entry {
    display: flex;
    gap: var(--space-sm);
    align-items: baseline;
  }

  .revision-entry time {
    white-space: nowrap;
    color: var(--color-text-muted);
    opacity: 0.7;
    flex-shrink: 0;
  }

  .revision-subject {
    color: var(--color-text-muted);
    text-decoration: none;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .revision-subject:hover {
    color: var(--color-accent);
  }
</style>
