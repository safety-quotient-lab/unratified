---
import { getCollection } from 'astro:content';
import { getPopularPosts } from '../lib/analytics';

const popular = await getPopularPosts(5);

// Look up post metadata for each popular slug
const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const postsBySlug = new Map(allPosts.map(p => [p.id, p]));

const items = popular
  .map(p => {
    const post = postsBySlug.get(p.slug);
    if (!post) return null;
    return { ...p, title: post.data.title };
  })
  .filter(Boolean) as { slug: string; views: number; title: string }[];
---

{items.length > 0 && (
  <section class="most-read">
    <h2>Most Read</h2>
    <ol>
      {items.map(item => (
        <li>
          <a href={`/${item.slug}/`}>{item.title}</a>
          <span class="view-count">{item.views} views</span>
        </li>
      ))}
    </ol>
  </section>
)}

<style>
  .most-read {
    margin-bottom: var(--space-2xl);
    padding: var(--space-lg);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    background: var(--color-surface-alt, var(--color-surface));
  }

  .most-read h2 {
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-md);
  }

  ol {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: most-read;
  }

  li {
    counter-increment: most-read;
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    padding: var(--space-xs) 0;
    border-bottom: 1px solid var(--color-border);
  }

  li:last-child {
    border-bottom: none;
  }

  li::before {
    content: counter(most-read) ".";
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    flex-shrink: 0;
    min-width: 1.2rem;
  }

  li a {
    font-size: 0.9rem;
    color: var(--color-heading);
    text-decoration: none;
    flex: 1;
  }

  li a:hover {
    color: var(--color-accent);
  }

  .view-count {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }
</style>
