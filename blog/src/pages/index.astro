---
import BlogLayout from '../layouts/BlogLayout.astro';
import PostList from '../components/PostList.svelte';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts
  .sort((a, b) =>
    new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime()
  )
  .map(post => ({
    id: post.id,
    title: post.data.title,
    summary: post.data.summary,
    publishedDate: new Date(post.data.publishedDate).toISOString(),
    author: post.data.author,
    tags: post.data.tags,
    reviewStatus: post.data.reviewStatus ?? 'unreviewed',
  }));

const allTags = [...new Set(allPosts.flatMap(p => p.data.tags))].sort();
---

<BlogLayout title="Posts">
  <div class="blog-index">
    <header>
      <h1>Unratified Blog</h1>
      <p class="lede">
        Analysis, updates, and community contributions on ICESCR ratification and AI economics.
      </p>
    </header>

    <PostList client:load posts={posts} allTags={allTags} />

    {posts.length === 0 && (
      <p>No posts yet. Check back soon.</p>
    )}
  </div>
</BlogLayout>

<style>
  .blog-index {
    max-width: var(--max-width-content);
    margin: 0 auto;
  }

  .lede {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 36rem;
    margin-bottom: var(--space-2xl);
  }
</style>
