---
import LensToggle from '../components/lens/LensToggle.svelte';
import ThemeToggle from '../components/lens/ThemeToggle.svelte';
import '../styles/base.css';
import '../styles/lens.css';

interface Props {
  title: string;
  description?: string;
  defaultLens?: 'voter' | 'politician' | 'developer' | 'educator' | 'researcher';
  ogType?: 'website' | 'article';
}

const {
  title,
  description = 'Advocating for U.S. ratification of the ICESCR through the lens of AI\'s economic impact',
  defaultLens = 'voter',
  ogType = 'website',
} = Astro.props;

const lensFromUrl = Astro.url.searchParams.get('lens') as Props['defaultLens'] | null;
const activeLens = lensFromUrl ?? defaultLens;
const siteOrigin = Astro.site?.origin ?? 'https://unratified.org';
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin);
const fullTitle = `${title} | Unratified`;

// Build breadcrumb items from URL path
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbItems = [
  { name: 'Home', url: `${siteOrigin}/` },
  ...pathSegments.map((seg, i) => ({
    name: seg.split('-').map((w) => w.charAt(0).toUpperCase() + w.slice(1)).join(' '),
    url: `${siteOrigin}/${pathSegments.slice(0, i + 1).join('/')}/`,
  })),
];

// Structured data graph
const structuredData: Record<string, unknown>[] = [
  {
    "@type": ogType === 'article' ? 'Article' : 'WebSite',
    "name": fullTitle,
    "description": description,
    "url": canonicalUrl.href,
    "publisher": {
      "@type": "Organization",
      "name": "Safety Quotient Lab",
      "url": "https://github.com/safety-quotient-lab",
      "founder": {
        "@type": "Person",
        "name": "Kashif Shah",
        "url": "https://kashifshah.net",
      },
    },
    "isPartOf": {
      "@type": "WebSite",
      "name": "Unratified",
      "url": siteOrigin,
    },
    "creator": [
      {
        "@type": "SoftwareApplication",
        "name": "Claude",
        "url": "https://www.anthropic.com/claude",
        "applicationCategory": "Artificial Intelligence",
        "provider": {
          "@type": "Organization",
          "name": "Anthropic",
          "url": "https://www.anthropic.com",
        },
      },
      {
        "@type": "Person",
        "name": "Kashif Shah",
        "url": "https://kashifshah.net",
      },
    ],
    ...(ogType === 'article' ? {
      "datePublished": "2026-03-02",
      "inLanguage": "en-US",
    } : {}),
  },
  {
    "@type": "BreadcrumbList",
    "itemListElement": breadcrumbItems.map((item, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": item.name,
      "item": item.url,
    })),
  },
];

// Add DefinedTermSet reference on non-glossary pages
if (Astro.url.pathname !== '/glossary') {
  structuredData[0] = {
    ...structuredData[0] as Record<string, unknown>,
    "mentions": {
      "@type": "DefinedTermSet",
      "name": "Unratified Glossary",
      "url": `${siteOrigin}/.well-known/glossary.json`,
    },
  };
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fafafa" />

    <!-- Blocking theme script: prevents flash of wrong theme -->
    <script is:inline>
      (function() {
        var t = localStorage.getItem('unratified-theme');
        if (!t && window.matchMedia('(prefers-color-scheme: dark)').matches) {
          t = 'dark';
        }
        if (t === 'dark') {
          document.documentElement.setAttribute('data-theme', 'dark');
          var m = document.querySelector('meta[name="theme-color"]');
          if (m) m.setAttribute('content', '#002d38');
        }
      })();
    </script>
    <link rel="canonical" href={canonicalUrl.href} />

    <!-- Fira Code font (non-render-blocking to prevent blank screen on slow connections) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300;400;500;600;700&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300;400;500;600;700&display=swap" /></noscript>

    <!-- DNS prefetch for external domains -->
    <link rel="dns-prefetch" href="https://www.senate.gov" />
    <link rel="dns-prefetch" href="https://braverangels.org" />
    <link rel="dns-prefetch" href="https://github.com" />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:site_name" content="Unratified" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": structuredData,
    })} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{fullTitle}</title>
    <!-- base.css and lens.css imported in frontmatter → Astro bundles with content hash -->
  </head>
  <body data-lens={activeLens}>
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <header class="site-header">
      <nav aria-label="Main navigation">
        <a href="/" class="site-title">Unratified</a>
        <ul class="nav-links">
          <li><a href="/covenant">The Covenant</a></li>
          <li><a href="/gap">The Gap</a></li>
          <li><a href="/connection">AI Connection</a></li>
          <li><a href="/evidence">Evidence</a></li>
          <li><a href="/educators">Educators</a></li>
          <li><a href="/action">Take Action</a></li>
          <li><a href="/resources">Resources</a></li>
          <li><a href="/glossary">Glossary</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="https://blog.unratified.org" rel="noopener">Blog &nearr;</a></li>
        </ul>
        <div class="nav-controls">
          <LensToggle client:load />
          <ThemeToggle client:load />
        </div>
      </nav>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-columns">
        <div class="footer-col">
          <p>A <a href="https://github.com/safety-quotient-lab" rel="noopener">Safety Quotient Lab</a> project by <a href="https://kashifshah.net" rel="noopener">Kashif Shah</a></p>
          <p><a href="https://creativecommons.org/licenses/by-sa/4.0/" rel="noopener">CC BY-SA 4.0</a></p>
          <p><a href="/colophon">Colophon</a> &middot; <a href="https://observatory.unratified.org" rel="noopener">Observatory &nearr;</a> &middot; <a href="mailto:kashif&#64;kashifshah.net">Contact</a></p>
        </div>
        <div class="footer-col">
          <p>Built by <a href="https://www.anthropic.com/claude" rel="noopener">Claude (Anthropic)</a></p>
          <p>Data by <a href="https://www.wolframalpha.com/" rel="noopener">Wolfram|Alpha</a></p>
          <p>Hosted on <a href="https://pages.cloudflare.com/" rel="noopener">Cloudflare</a></p>
        </div>
      </div>
      <p class="footer-note">
        Human Rights; Nothing More, Nothing Less.
      </p>
    </footer>
  </body>
</html>
