---
import LensToggle from '../components/lens/LensToggle.svelte';
import '../styles/base.css';
import '../styles/lens.css';

interface Props {
  title: string;
  description?: string;
  defaultLens?: 'voter' | 'politician' | 'developer' | 'educator' | 'researcher';
  ogType?: 'website' | 'article';
}

const {
  title,
  description = 'Advocating for U.S. ratification of the ICESCR through the lens of AI\'s economic impact',
  defaultLens = 'voter',
  ogType = 'website',
} = Astro.props;

const lensFromUrl = Astro.url.searchParams.get('lens') as Props['defaultLens'] | null;
const activeLens = lensFromUrl ?? defaultLens;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://unratified.org');
const fullTitle = `${title} | Unratified`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#002d38" />
    <link rel="canonical" href={canonicalUrl.href} />

    <!-- Fira Code font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <!-- DNS prefetch for external domains -->
    <link rel="dns-prefetch" href="https://www.senate.gov" />
    <link rel="dns-prefetch" href="https://braverangels.org" />
    <link rel="dns-prefetch" href="https://github.com" />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:site_name" content="Unratified" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": ogType === 'article' ? 'Article' : 'WebSite',
      "name": fullTitle,
      "description": description,
      "url": canonicalUrl.href,
      "publisher": {
        "@type": "Organization",
        "name": "Safety Quotient Lab",
        "url": "https://github.com/safety-quotient-lab"
      }
    })} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <!-- base.css and lens.css imported in frontmatter → Astro bundles with content hash -->
  </head>
  <body data-lens={activeLens}>
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <header class="site-header">
      <nav aria-label="Main navigation">
        <a href="/" class="site-title">Unratified</a>
        <ul class="nav-links">
          <li><a href="/covenant">The Covenant</a></li>
          <li><a href="/gap">The Gap</a></li>
          <li><a href="/connection">AI Connection</a></li>
          <li><a href="/evidence">Evidence</a></li>
          <li><a href="/educators">Educators</a></li>
          <li><a href="/action">Take Action</a></li>
          <li><a href="/resources">Resources</a></li>
        </ul>
        <LensToggle client:load />
      </nav>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        <a href="https://creativecommons.org/licenses/by-sa/4.0/" rel="noopener">CC BY-SA 4.0</a>
        &middot;
        A <a href="https://github.com/safety-quotient-lab" rel="noopener">Safety Quotient Lab</a> project
        &middot;
        <a href="https://observatory.unratified.org" rel="noopener">Observatory &nearr;</a>
      </p>
      <p class="footer-note">
        Human Rights, Nothing More, Nothing Less
      </p>
    </footer>
  </body>
</html>
