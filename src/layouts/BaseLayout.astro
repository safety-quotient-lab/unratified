---
import LensToggle from '../components/lens/LensToggle.svelte';

interface Props {
  title: string;
  description?: string;
  defaultLens?: 'developer' | 'educator' | 'researcher';
}

const {
  title,
  description = 'Advocating for U.S. ratification of the ICESCR through the lens of AI\'s economic impact',
  defaultLens = 'developer',
} = Astro.props;

const lensFromUrl = Astro.url.searchParams.get('lens') as Props['defaultLens'] | null;
const activeLens = lensFromUrl ?? defaultLens;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Unratified</title>
    <link rel="stylesheet" href="/styles/base.css" />
    <link rel="stylesheet" href="/styles/lens.css" />
  </head>
  <body data-lens={activeLens}>
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <header class="site-header">
      <nav aria-label="Main navigation">
        <a href="/" class="site-title">Unratified</a>
        <ul class="nav-links">
          <li><a href="/covenant">The Covenant</a></li>
          <li><a href="/gap">The Gap</a></li>
          <li><a href="/connection">AI Connection</a></li>
          <li><a href="/educators">Educators</a></li>
          <li><a href="/action">Take Action</a></li>
          <li><a href="/resources">Resources</a></li>
        </ul>
        <LensToggle client:load />
      </nav>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        <a href="https://creativecommons.org/licenses/by/4.0/" rel="noopener">CC BY 4.0</a>
        &middot;
        A <a href="https://github.com/safety-quotient-lab" rel="noopener">Safety Quotient Lab</a> project
      </p>
      <p class="footer-note">
        Human Rights, Nothing More, Nothing Less
      </p>
    </footer>
  </body>
</html>
