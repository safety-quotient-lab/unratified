---
import BaseLayout from './BaseLayout.astro';
import ObservatoryLink from '../components/ui/ObservatoryLink.astro';
import TableOfContents from '../components/ui/TableOfContents.svelte';
import { references, formatAPA, REFERENCE_CATEGORIES, getReferencesByCategory } from '../data/references';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  articleNumber: number;
  rightName: string;
  summary: string;
  aiConnection: string;
  legalText: string;
  pivotal?: boolean;
  udhrArticle?: number;
  udhrTitle?: string;
  prevArticle?: { number: number; slug: string; rightName: string };
  nextArticle?: { number: number; slug: string; rightName: string };
  headings?: Heading[];
}

const {
  title,
  articleNumber,
  rightName,
  summary,
  aiConnection,
  legalText,
  pivotal = false,
  udhrArticle,
  udhrTitle,
  prevArticle,
  nextArticle,
  headings = [],
} = Astro.props;
---

<BaseLayout title={`Article ${articleNumber}: ${rightName}`} description={summary}>
  <article class="article-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/covenant">The Covenant</a></li>
        <li aria-current="page">Article {articleNumber}</li>
      </ol>
    </nav>

    <header class="article-header">
      <span class="article-number">Article {articleNumber}</span>
      <h1>{rightName}</h1>
      <p class="article-summary">{summary}</p>
      {pivotal && <span class="pivotal-badge">Co-Pivotal Article</span>}
    </header>

    <div class="researcher-only structured-abstract content-section" data-section="abstract">
      <h2>Structured Abstract</h2>
      <dl>
        <dt>Subject</dt>
        <dd>ICESCR Article {articleNumber} — {rightName}</dd>
        <dt>Context</dt>
        <dd>{summary}</dd>
        <dt>AI Relevance</dt>
        <dd>{aiConnection}</dd>
      </dl>
    </div>

    <div class="educator-only learning-objectives content-section" data-section="objectives">
      <h2>Learning Objectives</h2>
      <p>After exploring this article, students should demonstrate ability to:</p>
      <ul>
        <li>Explain what Article {articleNumber} of the ICESCR protects in plain language</li>
        <li>Connect this right to observable conditions in their own community</li>
        <li>Analyze how AI-driven economic transformation affects this right</li>
        <li>Evaluate the consequences of the U.S. not ratifying this protection</li>
      </ul>
    </div>

    <div class="voter-only personal-impact content-section" data-section="impact">
      <h2>What This Means for You</h2>
      <p>{aiConnection}</p>
      <p>173 nations protect this right through binding law. The United States signed that commitment in 1977 and never followed through.</p>
      <p><a href="/action" class="impact-action-link">Take action on this right &rarr;</a></p>
    </div>

    <div class="politician-only policy-summary content-section" data-section="policy">
      <h2>Policy Summary</h2>
      <dl>
        <dt>Right Protected</dt>
        <dd>ICESCR Article {articleNumber} — {rightName}</dd>
        <dt>Current U.S. Status</dt>
        <dd>Signed 1977, unratified. No domestic legal obligation.</dd>
        <dt>AI Relevance</dt>
        <dd>{aiConnection}</dd>
        <dt>Committee</dt>
        <dd>Senate Foreign Relations Committee</dd>
      </dl>
      <p><a href="/action/policy-brief" class="policy-action-link">View full policy brief &rarr;</a></p>
    </div>

    <section class="legal-text-section">
      <details>
        <summary>Official Treaty Text</summary>
        <blockquote class="legal-text" cite="https://www.ohchr.org/en/instruments-mechanisms/instruments/international-covenant-economic-social-and-cultural-rights">
          <Fragment set:html={legalText} />
        </blockquote>
      </details>
    </section>

    <section class="article-content">
      <TableOfContents headings={headings} client:load />
      <slot />
    </section>

    <section class="ai-connection-callout">
      <h2>The AI Connection</h2>
      <p>{aiConnection}</p>
      <div class="callout-links">
        <a href={`/connection#article-${articleNumber}`}>Read the full analysis &rarr;</a>
        {udhrArticle && udhrTitle && (
          <ObservatoryLink
            udhrArticle={udhrArticle}
            udhrTitle={udhrTitle}
            icesCrArticle={articleNumber}
          />
        )}
        <a class="voter-only callout-action" href="/action">Take action on this right &rarr;</a>
        <a class="politician-only callout-action" href="/action/policy-brief">View policy brief &rarr;</a>
      </div>
    </section>

    <div class="educator-only discussion-prompt">
      <h3>Discussion Prompt</h3>
      <p>Consider how Article {articleNumber} applies to your community. What observable evidence supports or contradicts the protection of this right where you live?</p>
    </div>

    <section class="educator-only researcher-only reference-section">
      <h2 class="educator-only">References</h2>
      <h2 class="researcher-only">References</h2>
      <p class="ref-note">Sources cited across the Unratified analysis, formatted per APA 7th edition.</p>
      {REFERENCE_CATEGORIES.map(({ key, label }) => {
        const refs = getReferencesByCategory(key);
        if (!refs.length) return null;
        return (
          <div class="ref-group">
            <h3>{label}</h3>
            <ul class="ref-list">
              {refs.map((r) => (
                <li><span class="ref-text">{formatAPA(r)}</span></li>
              ))}
            </ul>
          </div>
        );
      })}
    </section>

    <section class="politician-only reference-section">
      <h2>Sources</h2>
      <ol class="endnote-list">
        {references.map((r, i) => (
          <li>
            <a href={r.url} rel="noopener">{r.title}</a>
            {r.authors[0]?.isOrganization
              ? ` — ${r.authors[0].family}`
              : r.authors[0]?.given
                ? ` — ${r.authors[0].family}, ${r.authors[0].given}`
                : ` — ${r.authors[0].family}`}
            {` (${r.year})`}
          </li>
        ))}
      </ol>
    </section>

    <nav class="article-nav" aria-label="Article navigation">
      {prevArticle && (
        <a href={`/covenant/articles/${prevArticle.slug}`} class="nav-prev">
          <span class="nav-label">&larr; Previous</span>
          <span class="nav-title">Article {prevArticle.number}: {prevArticle.rightName}</span>
        </a>
      )}
      {nextArticle && (
        <a href={`/covenant/articles/${nextArticle.slug}`} class="nav-next">
          <span class="nav-label">Next &rarr;</span>
          <span class="nav-title">Article {nextArticle.number}: {nextArticle.rightName}</span>
        </a>
      )}
    </nav>
  </article>
</BaseLayout>

<style>
  .article-page {
    max-width: var(--max-width-content);
    margin: 0 auto;
  }

  .breadcrumb ol {
    list-style: none;
    display: flex;
    gap: var(--space-sm);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
  }

  .breadcrumb li + li::before {
    content: '/';
    margin-right: var(--space-sm);
    color: var(--color-border);
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--color-accent);
  }

  .article-header {
    margin-bottom: var(--space-2xl);
  }

  .article-number {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
  }

  .article-header h1 {
    margin-top: var(--space-xs);
  }

  .article-summary {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 36rem;
  }

  .pivotal-badge {
    display: inline-block;
    margin-top: var(--space-sm);
    padding: var(--space-xs) var(--space-sm);
    background: var(--color-accent);
    color: var(--color-bg);
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 3px;
    letter-spacing: 0.03em;
  }

  .legal-text-section {
    margin: var(--space-xl) 0;
  }

  .legal-text-section details summary {
    cursor: pointer;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-muted);
    padding: var(--space-sm) 0;
  }

  .legal-text {
    font-size: 0.9rem;
    line-height: 1.7;
    border-left-color: var(--color-primary);
  }

  .article-content {
    margin: var(--space-xl) 0;
  }

  .ai-connection-callout {
    background: var(--color-surface-alt);
    border-left: 3px solid var(--color-accent);
    padding: var(--space-lg);
    margin: var(--space-2xl) 0;
    border-radius: 0 4px 4px 0;
  }

  .ai-connection-callout h2 {
    margin-top: 0;
    font-size: 1.1rem;
  }

  .callout-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    align-items: center;
    margin-top: var(--space-sm);
  }

  .callout-links a,
  .ai-connection-callout a {
    font-family: var(--font-heading);
    font-size: 0.875rem;
  }

  .callout-action {
    font-weight: 600;
  }

  .impact-action-link {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
  }

  .policy-action-link {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
  }

  .policy-summary dl {
    margin: var(--space-md) 0;
  }

  .policy-summary dt {
    font-weight: 600;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: var(--color-primary);
    margin-top: var(--space-md);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .policy-summary dt:first-child {
    margin-top: 0;
  }

  .policy-summary dd {
    margin: var(--space-xs) 0 0;
    font-size: 0.875rem;
    line-height: 1.55;
  }

  .article-nav {
    display: flex;
    justify-content: space-between;
    gap: var(--space-lg);
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .article-nav a {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    text-decoration: none;
    padding: var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    flex: 1;
    max-width: 18rem;
    transition: border-color 0.15s;
  }

  .article-nav a:hover {
    border-color: var(--color-accent);
  }

  .nav-next {
    text-align: right;
    margin-left: auto;
  }

  .nav-label {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .nav-title {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    color: var(--color-primary);
    font-weight: 500;
  }

  .reference-section {
    margin: var(--space-2xl) 0;
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .reference-section h2 {
    font-size: 1rem;
  }

  .ref-note {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .ref-group {
    margin-bottom: var(--space-lg);
  }

  .ref-group h3 {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xs);
  }

  .ref-list {
    list-style: none;
    margin: 0;
  }

  .ref-list li {
    padding: var(--space-xs) 0;
    font-size: 0.8rem;
    line-height: 1.5;
    border-bottom: 1px solid var(--color-surface-alt);
  }

  .ref-list li:last-child {
    border-bottom: none;
  }

  .endnote-list {
    margin: var(--space-md) 0;
    padding-left: var(--space-lg);
  }

  .endnote-list li {
    padding: var(--space-xs) 0;
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .endnote-list a {
    font-weight: 500;
  }
</style>
