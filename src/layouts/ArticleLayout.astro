---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  articleNumber: number;
  rightName: string;
  summary: string;
  aiConnection: string;
  legalText: string;
  pivotal?: boolean;
  prevArticle?: { number: number; slug: string; rightName: string };
  nextArticle?: { number: number; slug: string; rightName: string };
}

const {
  title,
  articleNumber,
  rightName,
  summary,
  aiConnection,
  legalText,
  pivotal = false,
  prevArticle,
  nextArticle,
} = Astro.props;
---

<BaseLayout title={`Article ${articleNumber}: ${rightName}`} description={summary}>
  <article class="article-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/covenant">The Covenant</a></li>
        <li aria-current="page">Article {articleNumber}</li>
      </ol>
    </nav>

    <header class="article-header">
      <span class="article-number">Article {articleNumber}</span>
      <h1>{rightName}</h1>
      <p class="article-summary">{summary}</p>
      {pivotal && <span class="pivotal-badge">Co-Pivotal Article</span>}
    </header>

    <div class="researcher-only structured-abstract content-section" data-section="abstract">
      <h2>Structured Abstract</h2>
      <dl>
        <dt>Subject</dt>
        <dd>ICESCR Article {articleNumber} — {rightName}</dd>
        <dt>Context</dt>
        <dd>{summary}</dd>
        <dt>AI Relevance</dt>
        <dd>{aiConnection}</dd>
      </dl>
    </div>

    <div class="educator-only learning-objectives content-section" data-section="objectives">
      <h2>Learning Objectives</h2>
      <p>After exploring this article, students should demonstrate ability to:</p>
      <ul>
        <li>Explain what Article {articleNumber} of the ICESCR protects in plain language</li>
        <li>Connect this right to observable conditions in their own community</li>
        <li>Analyze how AI-driven economic transformation affects this right</li>
        <li>Evaluate the consequences of the U.S. not ratifying this protection</li>
      </ul>
    </div>

    <section class="legal-text-section">
      <details>
        <summary>Official Treaty Text</summary>
        <blockquote class="legal-text" cite="https://www.ohchr.org/en/instruments-mechanisms/instruments/international-covenant-economic-social-and-cultural-rights">
          <Fragment set:html={legalText} />
        </blockquote>
      </details>
    </section>

    <section class="article-content">
      <slot />
    </section>

    <section class="ai-connection-callout">
      <h2>The AI Connection</h2>
      <p>{aiConnection}</p>
      <a href={`/connection#article-${articleNumber}`}>Read the full analysis &rarr;</a>
    </section>

    <div class="educator-only discussion-prompt">
      <h3>Discussion Prompt</h3>
      <p>Consider how Article {articleNumber} applies to your community. What observable evidence supports or contradicts the protection of this right where you live?</p>
    </div>

    <nav class="article-nav" aria-label="Article navigation">
      {prevArticle && (
        <a href={`/covenant/articles/${prevArticle.slug}`} class="nav-prev">
          <span class="nav-label">&larr; Previous</span>
          <span class="nav-title">Article {prevArticle.number}: {prevArticle.rightName}</span>
        </a>
      )}
      {nextArticle && (
        <a href={`/covenant/articles/${nextArticle.slug}`} class="nav-next">
          <span class="nav-label">Next &rarr;</span>
          <span class="nav-title">Article {nextArticle.number}: {nextArticle.rightName}</span>
        </a>
      )}
    </nav>
  </article>
</BaseLayout>

<style>
  .article-page {
    max-width: var(--max-width-content);
    margin: 0 auto;
  }

  .breadcrumb ol {
    list-style: none;
    display: flex;
    gap: var(--space-sm);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
  }

  .breadcrumb li + li::before {
    content: '/';
    margin-right: var(--space-sm);
    color: var(--color-border);
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--color-accent);
  }

  .article-header {
    margin-bottom: var(--space-2xl);
  }

  .article-number {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
  }

  .article-header h1 {
    margin-top: var(--space-xs);
  }

  .article-summary {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 36rem;
  }

  .pivotal-badge {
    display: inline-block;
    margin-top: var(--space-sm);
    padding: var(--space-xs) var(--space-sm);
    background: var(--color-accent);
    color: var(--color-bg);
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 3px;
    letter-spacing: 0.03em;
  }

  .legal-text-section {
    margin: var(--space-xl) 0;
  }

  .legal-text-section details summary {
    cursor: pointer;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-muted);
    padding: var(--space-sm) 0;
  }

  .legal-text {
    font-size: 0.9rem;
    line-height: 1.7;
    border-left-color: var(--color-primary);
  }

  .article-content {
    margin: var(--space-xl) 0;
  }

  .ai-connection-callout {
    background: var(--color-surface-alt);
    border-left: 3px solid var(--color-accent);
    padding: var(--space-lg);
    margin: var(--space-2xl) 0;
    border-radius: 0 4px 4px 0;
  }

  .ai-connection-callout h2 {
    margin-top: 0;
    font-size: 1.1rem;
  }

  .ai-connection-callout a {
    display: inline-block;
    margin-top: var(--space-sm);
    font-family: var(--font-heading);
    font-size: 0.875rem;
  }

  .article-nav {
    display: flex;
    justify-content: space-between;
    gap: var(--space-lg);
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .article-nav a {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    text-decoration: none;
    padding: var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    flex: 1;
    max-width: 18rem;
    transition: border-color 0.15s;
  }

  .article-nav a:hover {
    border-color: var(--color-accent);
  }

  .nav-next {
    text-align: right;
    margin-left: auto;
  }

  .nav-label {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .nav-title {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    color: var(--color-primary);
    font-weight: 500;
  }
</style>
