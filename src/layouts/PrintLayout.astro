---
/**
 * PrintLayout — light-background, print-optimized layout for educator resources.
 * Does NOT inherit BaseLayout. Loads zero dark-theme CSS.
 * Teachers open these pages and use Ctrl+P / Cmd+P to save as PDF.
 */

interface Props {
  title: string;
  gradeLevel: string;
  duration?: string;
  type: 'teacher-guide' | 'student-handout';
}

const { title, gradeLevel, duration, type } = Astro.props;
const typeLabel = type === 'teacher-guide' ? 'Teacher Guide' : 'Student Handout';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;600&display=swap" rel="stylesheet" />
    <title>{title} — Unratified.org</title>
  </head>
  <body>
    <header class="print-header">
      <div class="print-meta">
        <span class="badge grade-badge">{gradeLevel}</span>
        {duration && <span class="badge duration-badge">{duration}</span>}
        <span class="badge type-badge">{typeLabel}</span>
      </div>
      <h1>{title}</h1>
    </header>

    <div class="print-actions no-print">
      <button onclick="window.print()">Print / Save as PDF</button>
      <a href="/action/educator-toolkit">← Back to Educator Toolkit</a>
      <a href="/educators">← Educators Hub</a>
    </div>

    <main class="print-content">
      <slot />
    </main>

    <footer class="print-footer">
      <p>
        CC BY-SA 4.0 — Safety Quotient Lab —
        Full materials and citations at unratified.org/action/educator-toolkit
      </p>
    </footer>
  </body>
</html>

<style is:global>
  /* Print Layout — Light Theme (no dark CSS loaded) */
  :root {
    --print-bg: #ffffff;
    --print-text: #1a1a1a;
    --print-text-muted: #444444;
    --print-border: #cccccc;
    --print-accent: #0066aa;
    --print-green: #2a6a00;
    --font-display: 'Fira Code', monospace;
    --font-body: Georgia, 'Times New Roman', serif;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html, body {
    background: var(--print-bg);
    color: var(--print-text);
    font-family: var(--font-body);
    font-size: 11pt;
    line-height: 1.5;
  }

  h1 {
    font-family: var(--font-display);
    font-size: 20pt;
    font-weight: 600;
    color: var(--print-text);
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }

  h2 {
    font-family: var(--font-display);
    font-size: 14pt;
    font-weight: 600;
    color: var(--print-green);
    margin: 1.5rem 0 0.5rem;
    border-bottom: 1px solid var(--print-border);
    padding-bottom: 0.25rem;
    line-height: 1.3;
  }

  h3 {
    font-family: var(--font-display);
    font-size: 12pt;
    font-weight: 600;
    color: var(--print-text);
    margin: 1rem 0 0.25rem;
    line-height: 1.3;
  }

  h4 {
    font-size: 11pt;
    font-weight: 600;
    margin: 0.75rem 0 0.25rem;
  }

  p {
    margin-bottom: 0.75rem;
    max-width: none;
  }

  a {
    color: var(--print-accent);
    text-decoration: underline;
  }

  strong { font-weight: 600; }
  em { font-style: italic; }

  /* Tables — APA style, print-safe */
  table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 10pt;
    page-break-inside: avoid;
  }

  thead {
    border-top: 2px solid var(--print-text);
    border-bottom: 1px solid var(--print-text);
  }

  tbody {
    border-bottom: 2px solid var(--print-text);
  }

  th, td {
    padding: 0.3rem 0.5rem;
    text-align: left;
  }

  th {
    font-family: var(--font-display);
    font-weight: 600;
  }

  ul, ol {
    margin: 0.5rem 0 0.75rem 1.5rem;
  }

  li {
    margin-bottom: 0.25rem;
  }

  blockquote {
    border-left: 3px solid var(--print-border);
    padding-left: 1rem;
    margin: 0.75rem 0;
    color: var(--print-text-muted);
    font-style: italic;
  }

  code {
    font-family: var(--font-display);
    font-size: 0.9em;
    background: #f5f5f5;
    padding: 0.1em 0.3em;
    border-radius: 2px;
  }

  hr {
    border: none;
    border-top: 1px solid var(--print-border);
    margin: 1.5rem 0;
  }

  /* Badges */
  .badge {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--print-text);
    border-radius: 3px;
    font-family: var(--font-display);
    font-size: 9pt;
    margin-right: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .type-badge {
    background: var(--print-text);
    color: var(--print-bg);
  }

  /* Layout containers */
  .print-header {
    max-width: 7.5in;
    margin: 1rem auto 0;
    padding: 0 1rem 0.75rem;
    border-bottom: 2px solid var(--print-text);
  }

  .print-meta {
    margin-bottom: 0.5rem;
  }

  .print-actions {
    max-width: 7.5in;
    margin: 0.75rem auto;
    padding: 0 1rem;
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .print-actions button {
    padding: 0.4rem 1rem;
    background: var(--print-text);
    color: var(--print-bg);
    border: none;
    font-family: var(--font-display);
    font-size: 10pt;
    cursor: pointer;
    border-radius: 3px;
  }

  .print-actions button:hover {
    opacity: 0.8;
  }

  .print-actions a {
    font-family: var(--font-display);
    font-size: 10pt;
  }

  .print-content {
    max-width: 7.5in;
    margin: 1rem auto;
    padding: 0 1rem;
  }

  .print-footer {
    max-width: 7.5in;
    margin: 1.5rem auto 1rem;
    padding: 0.5rem 1rem 0;
    border-top: 1px solid var(--print-border);
    font-family: var(--font-display);
    font-size: 8pt;
    color: var(--print-text-muted);
  }

  /* Writing space for student handouts */
  .writing-space {
    border: 1px solid var(--print-border);
    border-radius: 3px;
    padding: 1rem;
    margin: 1rem 0;
    min-height: 3in;
    background: #fafafa;
  }

  .writing-space p {
    color: var(--print-text-muted);
    font-style: italic;
    margin: 0;
  }

  /* Hide download cards if they render inside print pages */
  .download-card {
    display: none;
  }

  /* Print-specific rules */
  @media print {
    @page {
      margin: 1in;
      size: letter;
    }

    .no-print {
      display: none !important;
    }

    body {
      font-size: 10pt;
    }

    h1 { font-size: 18pt; }
    h2 { font-size: 13pt; color: var(--print-text); }
    h3 { font-size: 11pt; }

    a { color: var(--print-text); }

    .print-header {
      padding: 0 0 0.5rem;
    }

    .print-content {
      padding: 0;
    }

    .print-footer {
      padding: 0.5rem 0 0;
    }

    table { page-break-inside: avoid; }
    h2, h3, h4 { page-break-after: avoid; }
    p { orphans: 3; widows: 3; }

    .writing-space {
      background: white;
      min-height: 4in;
    }
  }
</style>
