---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const pages = await getCollection('evidence');
  return pages.map((page) => ({
    params: { slug: page.id },
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content } = await render(page);
---

<BaseLayout title={page.data.title} description={page.data.summary}>
  <article class="evidence-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/evidence">The Evidence</a></li>
        <li aria-current="page">{page.data.title}</li>
      </ol>
    </nav>

    <header>
      <h1>{page.data.title}</h1>
      <p class="lede">{page.data.summary}</p>
    </header>

    <div class="content">
      <Content />
    </div>

    <nav class="section-nav">
      <a href="/evidence">&larr; Back to The Evidence</a>
    </nav>
  </article>
</BaseLayout>

<style>
  .evidence-page {
    max-width: var(--max-width-content);
    margin: 0 auto;
  }

  .breadcrumb ol {
    list-style: none;
    display: flex;
    gap: var(--space-sm);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
  }

  .breadcrumb li + li::before {
    content: '/';
    margin-right: var(--space-sm);
    color: var(--color-border);
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .lede {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 36rem;
  }

  .content {
    margin-top: var(--space-xl);
  }

  .content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-lg) 0;
    font-size: 0.875rem;
  }

  .content :global(th),
  .content :global(td) {
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--color-border);
    text-align: left;
  }

  .content :global(th) {
    background: var(--color-surface);
    font-weight: 600;
  }

  .content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    margin: var(--space-lg) 0;
    padding: var(--space-sm) var(--space-lg);
    color: var(--color-text-muted);
    font-style: italic;
  }

  .content :global(ul),
  .content :global(ol) {
    margin: var(--space-md) 0 var(--space-md) var(--space-xl);
  }

  .content :global(li) {
    margin-bottom: var(--space-sm);
  }

  .section-nav {
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .section-nav a {
    font-family: var(--font-heading);
    font-size: 0.875rem;
  }
</style>
