---
import SectionLayout from '../../layouts/SectionLayout.astro';
import LensPanel from '../../components/LensPanel.astro';
import { getCollection } from 'astro:content';
import { getObservatoryStats } from '../../data/observatory';

const pages = await getCollection('evidence');
const sorted = pages.sort((a, b) => a.data.order - b.data.order);
const obs = await getObservatoryStats();

const lensFraming = {
  voter: "The numbers behind the analysis — tariff costs, job projections, AI adoption rates, and safety net changes. These data points show how economic forces converge on your household budget, your healthcare, and your job market.",
  politician: "Empirical dataset: tariff household costs ($1,500/yr, Yale Budget Lab), employment projections (-550K, Tax Foundation), AI capex ($527B, Goldman Sachs), OBBBA Medicaid reduction ($990B, CBO), AI adoption rates (34/37 split, Deloitte). Each data point connects to specific ICESCR provisions.",
  developer: "Evidence corpus: 2 primary documents. Economic landscape — macro data (tariffs, AI capex, conflicts, supply chains) with source links. Research summary — 6-paper analytical chain with discriminator scores at each layer. Sources: Yale Budget Lab, Tax Foundation, Goldman Sachs, Deloitte, WEF, CBO.",
  educator: "This section provides real-world data for classroom analysis. Students can trace causal chains from policy decisions to household outcomes, evaluate compound effects across multiple economic forces, and practice distinguishing empirical observation from inference.",
  researcher: "Empirical evidence base: macroeconomic landscape (March 2026 snapshot) and meta-analytical research summary (six discriminator-scored analyses). Sources: Tax Foundation tariff tracker, Yale Budget Lab state-of-tariffs analysis, Goldman Sachs AI capex projections, WEF Global Risks Report 2026, Deloitte enterprise AI survey, CBO OBBBA scoring.",
};

const cardStats: Record<string, { number: string; label: string; variant?: string }> = {
  'economic-landscape': { number: '$990B', label: 'Medicaid Cuts', variant: 'figure' },
  'research-summary': { number: '5', label: 'Surviving Hypotheses' },
};
---

<SectionLayout
  title="The Evidence"
  description="Empirical data and current conditions — the observable foundation for connecting AI-driven economic transformation to ICESCR-protected rights."
  section="evidence"
>
  <LensPanel lensFraming={lensFraming} section="evidence" />

  <div class="evidence-grid">
    {sorted.map((page) => (
      <a href={`/evidence/${page.id}`} class="evidence-card">
        {cardStats[page.id] && (
          <span class={`card-visual card-visual--${cardStats[page.id].variant || 'stat'}`}>
            <span class="visual-number">{cardStats[page.id].number}</span>
            <span class="visual-label">{cardStats[page.id].label}</span>
          </span>
        )}
        <h2>{page.data.title}</h2>
        <p>{page.data.summary}</p>
      </a>
    ))}
  </div>

  <section class="evidence-note">
    <h2>Methodology</h2>
    <p>
      Every claim on this site traces back to observable data — empirical studies,
      government statistics, or documented policy actions. Where analysis extends
      beyond direct observation, the inference chain appears explicitly.
    </p>
    <p>
      The <a href="/connection/differential-diagnosis">differential diagnosis</a> scores
      each hypothesis against five dimensions: empirical support, parsimony, consensus,
      chain integrity, and predictive power. No hypothesis receives a pass without
      surviving all five.
    </p>
    <p>
      <a href="/connection">Explore the full analysis &rarr;</a>
    </p>
  </section>

  <section class="cross-section-nav">
    <h2>These Numbers Connect to Your Rights</h2>
    <p>
      The evidence documented here directly informs the <a href="https://www.ohchr.org/en/instruments-mechanisms/instruments/international-covenant-economic-social-and-cultural-rights" rel="noopener">ICESCR</a> <a href="/covenant">articles</a>
      protecting your economic rights. The <a href="/connection">AI Connection</a> traces how
      AI productivity data, tariff effects, and safety net cuts translate into rights-relevant
      consequences through the <a href="/glossary#composite-a">Composite A</a> analytical model.
    </p>
    <p>
      What has prevented ratification: <a href="/gap">The Gap</a> |
      What you can do: <a href="/action">Take Action</a> |
      <a href="/glossary">Glossary of terms</a>
    </p>
  </section>

  <section class="observatory-callout">
    <h2>Live Signal Dashboard</h2>
    <p>
      The <a href="https://observatory.unratified.org/signals" rel="noopener">Human Rights Observatory</a>
      has evaluated <strong>{obs.corpusSize.toLocaleString()}+</strong> Hacker News stories against the
      Universal Declaration. Current findings: {obs.authorIdentifiedPct}% of authors identified,
      {obs.highJargonPct}% use heavy jargon, and {obs.domainSpecificPct}% assume domain-specific knowledge.
    </p>
  </section>
</SectionLayout>

<style>
  .evidence-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
  }

  .evidence-card {
    display: block;
    padding: var(--space-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.15s;
  }

  .evidence-card:hover {
    border-color: var(--color-accent);
  }

  .evidence-card h2 {
    font-size: 1.1rem;
    margin-top: 0;
    margin-bottom: var(--space-sm);
  }

  .evidence-card p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .evidence-note {
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .cross-section-nav {
    padding: var(--space-lg);
    background: var(--color-surface-alt);
    border-left: 3px solid var(--color-accent);
    border-radius: 0 4px 4px 0;
    margin-bottom: var(--space-2xl);
  }

  .cross-section-nav h2 {
    margin-top: 0;
    font-size: 1.1rem;
  }

  .cross-section-nav p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .cross-section-nav a {
    font-weight: 500;
  }
</style>
