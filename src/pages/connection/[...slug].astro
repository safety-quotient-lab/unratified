---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CausalChain from '../../components/ui/CausalChain.svelte';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const pages = await getCollection('connection');
  return pages.map((page) => ({
    params: { slug: page.id },
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content } = await render(page);
const showChain = page.id === 'differential-diagnosis' || page.id === 'higher-order-effects';
---

<BaseLayout title={page.data.title} description={page.data.summary}>
  <article class="connection-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/connection">AI Connection</a></li>
        <li aria-current="page">{page.data.title}</li>
      </ol>
    </nav>

    <header>
      <h1>{page.data.title}</h1>
      <p class="lede">{page.data.summary}</p>
      {page.data.relatedArticles.length > 0 && (
        <div class="related">
          <span class="related-label">Related articles:</span>
          {page.data.relatedArticles.map((num: number) => (
            <a href={`/covenant/articles/article-${num}`} class="article-link">Art. {num}</a>
          ))}
        </div>
      )}
    </header>

    {showChain && (
      <section class="chain-section" aria-label="Interactive causal chain visualization">
        <h2>Causal Chain Visualization</h2>
        <p class="chain-section-note">
          The view adapts to your selected lens — use the lens toggle in the navigation
          to switch between Educator (accordion), Developer (flowchart), and Researcher (step-through).
        </p>
        <CausalChain client:visible />
      </section>
    )}

    <div class="content">
      <Content />
    </div>

    <nav class="section-nav">
      <a href="/connection">&larr; Back to The AI Connection</a>
    </nav>
  </article>
</BaseLayout>

<style>
  .connection-page {
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  .chain-section {
    margin: var(--space-2xl) 0;
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .chain-section-note {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .breadcrumb ol {
    list-style: none;
    display: flex;
    gap: var(--space-sm);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
  }

  .breadcrumb li + li::before {
    content: '/';
    margin-right: var(--space-sm);
    color: var(--color-border);
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .lede {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 36rem;
  }

  .related {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-md);
    flex-wrap: wrap;
  }

  .related-label {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .article-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 2px var(--space-sm);
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    color: var(--color-accent);
    text-decoration: none;
  }

  .article-link:hover {
    background: var(--color-surface);
    border-color: var(--color-accent);
  }

  .content {
    margin-top: var(--space-xl);
  }

  .content :global(ul),
  .content :global(ol) {
    margin: var(--space-md) 0 var(--space-md) var(--space-xl);
  }

  .content :global(li) {
    margin-bottom: var(--space-sm);
  }

  .section-nav {
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .section-nav a {
    font-family: var(--font-heading);
    font-size: 0.875rem;
  }
</style>
