---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LensPanel from '../../components/LensPanel.astro';
import CausalChain from '../../components/ui/CausalChain.svelte';
import ScoreChart from '../../components/ui/ScoreChart.svelte';
import RadarChart from '../../components/ui/RadarChart.svelte';
import TableOfContents from '../../components/ui/TableOfContents.svelte';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const pages = await getCollection('connection');
  return pages.map((page) => ({
    params: { slug: page.id },
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content, headings } = await render(page);
const showChain = page.id === 'ai/differential-diagnosis' || page.id === 'ai/higher-order-effects';
const showHypothesisChart = page.id === 'ai/differential-diagnosis';
const showScenarioChart = page.id === 'ai/ratification-counterfactual';
const showRadar = page.id === 'ai/dignity-quotient';

// Derive domain for breadcrumb
const domain = page.id.split('/')[0];
const domainLabels: Record<string, { label: string; href: string }> = {
  ai: { label: 'AI & Economic Rights', href: '/connection/ai' },
  enforcement: { label: 'Enforcement & Economic Rights', href: '/connection/enforcement' },
  international: { label: 'International & Accountability', href: '/connection/international' },
};

const hypothesisItems = [
  { label: 'H4: Bottleneck Migration', score: 20, status: 'survived' as const },
  { label: 'H7: Bifurcated Economy', score: 19, status: 'survived' as const },
  { label: 'H2: Constraint Removal', score: 17, status: 'survived' as const },
  { label: 'H3: Jevons Explosion', score: 17, status: 'survived' as const },
  { label: 'H6: Quality Erosion', score: 16, status: 'modulator' as const },
  { label: 'H1: Productivity Multiplier', score: 0, status: 'eliminated' as const },
  { label: 'H5: Recursive Acceleration', score: 0, status: 'eliminated' as const },
];

const scenarioItems = [
  { label: 'R6: Compliance Theater', score: 18, status: 'survived' as const },
  { label: 'R3: Institutional Capacity', score: 17, status: 'survived' as const },
  { label: 'R5: Quality Floor', score: 17, status: 'survived' as const },
  { label: 'R7: Litigation Explosion', score: 16, status: 'survived' as const },
  { label: 'R4: Bifurcation Mitigation', score: 15, status: 'retained' as const },
  { label: 'R1: Directed Acceleration', score: 13, status: 'eliminated' as const },
  { label: 'R2: Channeled Explosion', score: 13, status: 'eliminated' as const },
];

const dqDimensions = [
  { key: 'TE', label: 'Threat Exposure' },
  { key: 'RC', label: 'Regulatory Capacity' },
  { key: 'RB', label: 'Resilience Baseline' },
  { key: 'TC', label: 'Trust Conditions' },
  { key: 'HI', label: 'Hostility Index' },
  { key: 'CC', label: 'Cooling Capacity' },
  { key: 'ED', label: 'Energy Dissipation' },
  { key: 'DA', label: 'Defensive Architecture' },
  { key: 'AD', label: 'Authority Dynamics' },
  { key: 'CO', label: 'Contractual Clarity' },
];

const dqProfiles = [
  {
    name: 'Full UDHR Average',
    values: { TE: 6.3, RC: 5.3, RB: 6.4, TC: 5.8, HI: 6.6, CC: 4.3, ED: 4.3, DA: 6.6, AD: 4.9, CO: 6.7 },
  },
];
---

<BaseLayout title={page.data.title} description={page.data.summary}>
  <article class="connection-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/connection">The Connections</a></li>
        {domainLabels[domain] && (
          <li><a href={domainLabels[domain].href}>{domainLabels[domain].label}</a></li>
        )}
        <li aria-current="page">{page.data.title}</li>
      </ol>
    </nav>

    <header>
      <h1>{page.data.title}</h1>
      <p class="lede">{page.data.summary}</p>
      {page.data.relatedArticles.length > 0 && (
        <div class="related">
          <span class="related-label">Related articles:</span>
          {page.data.relatedArticles.map((num: number) => (
            <a href={`/covenant/articles/article-${num}`} class="article-link">Art. {num}</a>
          ))}
        </div>
      )}
    </header>

    {showChain && (
      <section class="chain-section" aria-label="Interactive causal chain visualization">
        <h2>Causal Chain Visualization</h2>
        <p class="chain-section-note">
          The view adapts to your selected lens — use the lens toggle in the navigation
          to switch between Educator (accordion), Developer (flowchart), and Researcher (step-through).
        </p>
        <CausalChain client:visible />
      </section>
    )}

    {showHypothesisChart && (
      <section class="chart-section" aria-label="Hypothesis scoring visualization">
        <h2>Hypothesis Scores</h2>
        <p class="chart-note">
          Each hypothesis underwent discriminator scoring across five dimensions
          (empirical support, parsimony, chain integrity, predictive power, scope)
          at 0–5 each, total out of 25.
        </p>
        <ScoreChart
          client:visible
          items={hypothesisItems}
          maxScore={25}
          title="Differential Diagnosis — Hypothesis Scores"
          showStatus={true}
        />
      </section>
    )}

    {showScenarioChart && (
      <section class="chart-section" aria-label="Ratification scenario scoring visualization">
        <h2>Scenario Scores</h2>
        <p class="chart-note">
          Seven ratification scenarios evaluated through the same discriminator framework.
        </p>
        <ScoreChart
          client:visible
          items={scenarioItems}
          maxScore={25}
          title="Ratification Counterfactual — Scenario Scores"
          showStatus={true}
        />
      </section>
    )}

    {showRadar && (
      <section class="chart-section" aria-label="Dignity Quotient radar visualization">
        <h2>PSQ Dimension Profile</h2>
        <p class="chart-note">
          The UDHR's dignity profile across 10 psychoemotional safety dimensions,
          revealing peaks in boundary protection and valleys in stress processing.
        </p>
        <RadarChart
          client:visible
          dimensions={dqDimensions}
          profiles={dqProfiles}
          title="Dignity Quotient — UDHR PSQ Profile"
        />
      </section>
    )}

    <LensPanel lensFraming={page.data.lensFraming} section="connection" />

    <TableOfContents headings={headings} client:load />

    <div class="content">
      <Content />
    </div>

    <nav class="section-nav">
      {domainLabels[domain] ? (
        <>
          <a href={domainLabels[domain].href}>&larr; {domainLabels[domain].label}</a>
          <span class="section-nav-sep">&middot;</span>
          <a href="/connection">The Connections</a>
        </>
      ) : (
        <a href="/connection">&larr; The Connections</a>
      )}
    </nav>
  </article>
</BaseLayout>

<style>
  .connection-page {
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  .chain-section {
    margin: var(--space-2xl) 0;
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .chain-section-note {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .chart-section {
    margin: var(--space-2xl) 0;
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .chart-note {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .breadcrumb ol {
    list-style: none;
    display: flex;
    gap: var(--space-sm);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
  }

  .breadcrumb li + li::before {
    content: '/';
    margin-right: var(--space-sm);
    color: var(--color-border);
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .lede {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 36rem;
  }

  .related {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-md);
    flex-wrap: wrap;
  }

  .related-label {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .article-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 2px var(--space-sm);
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    color: var(--color-accent);
    text-decoration: none;
  }

  .article-link:hover {
    background: var(--color-surface);
    border-color: var(--color-accent);
  }

  .content {
    margin-top: var(--space-xl);
  }

  .content :global(ul),
  .content :global(ol) {
    margin: var(--space-md) 0 var(--space-md) var(--space-xl);
  }

  .content :global(li) {
    margin-bottom: var(--space-sm);
  }

  .section-nav {
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .section-nav a {
    font-family: var(--font-heading);
    font-size: 0.875rem;
  }

  .section-nav-sep {
    color: var(--color-border);
    margin: 0 var(--space-sm);
  }
</style>
