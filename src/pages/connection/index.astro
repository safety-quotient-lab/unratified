---
import SectionLayout from '../../layouts/SectionLayout.astro';
import LensPanel from '../../components/LensPanel.astro';
import { getCollection } from 'astro:content';
import { getObservatoryStats } from '../../data/observatory';

const pages = await getCollection('connection');
const sorted = pages.sort((a, b) => a.data.order - b.data.order);
const obs = await getObservatoryStats();

const lensFraming = {
  voter: "This section explains how AI changes the economy and what that means for your rights. Four analyses trace the chain from 'AI makes software nearly free' through 'your job market changes' to 'these specific treaty protections would help.'",
  politician: "Four analytical papers connecting AI economic transformation to ICESCR provisions: differential diagnosis (7 hypotheses, 4 survivors), higher-order effects (Four Scarcities model), ratification counterfactual (ADA pattern), and Dignity Quotient (PSQ-UDHR framework). Each maps specific economic effects to specific treaty articles.",
  developer: "Analytical pipeline: 7 hypotheses → Composite A (H2+H3+H4+H7 mod H6, 20/25) → Four Scarcities → ratification counterfactual (Composite R-A) → Dignity Quotient (5.7/10). Discriminator scoring at each layer. Interactive: ScoreChart, RadarChart, CausalChain components.",
  educator: "These four analyses model structured analytical methodology — differential diagnosis, knock-on analysis, counterfactual reasoning, and measurement framework design. Students can evaluate each hypothesis against evidence, trace causal chains, and assess how confidence degrades at higher analytical orders.",
  researcher: "Four-paper analytical chain applying differential diagnosis with consensus/parsimony discriminator to AI economic impact. Composite A (H2+H3+H4+H7 mod H6, 20/25) → recursive higher-order analysis revealing Four Scarcities → ratification counterfactual (Composite R-A, R3+R5+R6 activated by R7) → Dignity Quotient (PSQ-UDHR, 5.7/10). Confidence degradation documented at each order.",
};
---

<SectionLayout
  title="The AI Connection"
  description="How AI-driven economic transformation maps onto the rights the ICESCR protects — differential diagnosis, knock-on effects, and the ratification counterfactual."
  section="connection"
  breadcrumbLabel="AI Connection"
>
  <LensPanel lensFraming={lensFraming} section="connection" />

  <section class="tagline">
    <blockquote>
      One of Anthropic Claude's takes on the impact of AI on the economy — differential diagnosis, integral chain analysis, and what it means for your rights
    </blockquote>
    <p class="meta-note">
      This analysis emerged through structured dialogue between a human researcher and Claude (Anthropic's AI). The meta-layer — an AI analyzing AI's own economic impact — forms part of the site's intellectual honesty.
    </p>
  </section>

  <div class="analysis-grid">
    {sorted.map((page) => (
      <a href={`/connection/${page.id}`} class="analysis-card">
        <span class="card-order">Part {page.data.order}</span>
        {page.data.relatedArticles.length > 0 && (
          <span class="card-visual card-visual--stat">
            <span class="visual-number">{page.data.relatedArticles.length}</span>
            <span class="visual-label">ICESCR Articles</span>
          </span>
        )}
        <h2>{page.data.title}</h2>
        <p>{page.data.summary}</p>
        {page.data.relatedArticles.length > 0 && (
          <div class="related-articles">
            {page.data.relatedArticles.map((num: number) => (
              <span class="article-tag">Art. {num}</span>
            ))}
          </div>
        )}
      </a>
    ))}
  </div>

  <section class="reading-guide">
    <h2>Reading Guide</h2>
    <p>
      The analysis builds sequentially: the differential diagnosis establishes the mechanism,
      higher-order effects trace its consequences, the ratification counterfactual explores
      what changes with ICESCR protection, and the Dignity Quotient provides a measurement
      framework connecting psychology to human rights.
    </p>
    <p>
      Each section connects to specific ICESCR articles — follow the article tags to see
      how the analysis maps onto <a href="/covenant">the covenant</a>.
    </p>
  </section>

  <section class="observatory-callout">
    <h2>Live Evidence</h2>
    <p>
      The <a href="https://observatory.unratified.org" rel="noopener">Human Rights Observatory</a>
      tracks how the tech community discusses all 30 UDHR articles — {obs.corpusSize.toLocaleString()}+
      stories evaluated so far. The ICESCR rights analyzed here map directly to observable
      discourse patterns in the Observatory.
    </p>
    <p class="observatory-links">
      <a href="https://observatory.unratified.org/rights/articles" rel="noopener" class="lens-developer">
        Rights signal corpus — all 31 UDHR provisions &nearr;
      </a>
      <a href="https://observatory.unratified.org/rights/articles" rel="noopener" class="lens-educator">
        See which rights the tech community discusses most &nearr;
      </a>
      <a href="https://observatory.unratified.org/rights/articles" rel="noopener" class="lens-researcher">
        UDHR article scores, HRCB metrics, FW ratios — evidence corpus &nearr;
      </a>
      <a href="https://observatory.unratified.org/rights/network" rel="noopener" class="lens-researcher">
        Rights correlation network — MST backbone &nearr;
      </a>
    </p>
  </section>
</SectionLayout>

<style>
  .tagline {
    margin-bottom: var(--space-2xl);
    max-width: var(--max-width-content);
  }

  .tagline blockquote {
    font-size: 1.1rem;
    font-style: italic;
    color: var(--color-text-muted);
    border-left-color: var(--color-accent);
  }

  .meta-note {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .analysis-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
  }

  .analysis-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.15s;
  }

  .analysis-card:hover {
    border-color: var(--color-accent);
  }

  .card-order {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
  }

  .analysis-card h2 {
    margin: 0;
    font-size: 1.1rem;
  }

  .analysis-card p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin: 0;
    flex: 1;
  }

  .related-articles {
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
  }

  .article-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 2px var(--space-xs);
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    color: var(--color-text-muted);
  }

  .reading-guide {
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  /* Observatory callout base styles now in base.css (D022) */
  .observatory-links a {
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    display: none;
  }

  /* Show only the active lens links */
  [data-lens="developer"] .lens-developer,
  :not([data-lens]) .lens-developer { display: inline; }
  [data-lens="educator"] .lens-educator { display: inline; }
  [data-lens="researcher"] .lens-researcher { display: inline; }
</style>
