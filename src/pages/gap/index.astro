---
import SectionLayout from '../../layouts/SectionLayout.astro';
import LensPanel from '../../components/LensPanel.astro';
import { getCollection } from 'astro:content';
import { getObservatoryStats } from '../../data/observatory';

const pages = await getCollection('gap');
const sorted = pages.sort((a, b) => a.data.order - b.data.order);
const obs = await getObservatoryStats();

const lensFraming = {
  voter: "Why haven't you heard of the ICESCR? This section traces the 49-year gap between the U.S. signing this treaty and... nothing. Five pages explore why the Senate never voted and what that inaction costs you.",
  politician: "The ICESCR remains pending before the SFRC since 1977 — 49 years without a committee hearing. This section documents the procedural history, analyzes the five core objections to ratification, and evaluates each against evidence. Reference: SFRC jurisdiction, Article II Section 2 process.",
  developer: "ICESCR pipeline state: signed (1977), transmitted to SFRC, never scheduled. 5 subsections: timeline (49 years), arguments (5 objections), counterarguments (5 rebuttals), rights misconceptions (3), global comparison (173 ratifiers). Data: Senate.gov, OHCHR treaty body database.",
  educator: "Use this section as source material for teaching about treaty ratification and the gap between aspiration and commitment. Your students analyze why the U.S. ratified the ICCPR but not the ICESCR, evaluate the five core objections, and trace the procedural history — connecting civics and international law.",
  researcher: "Historical and comparative analysis of ICESCR non-ratification. Methodological approach: process tracing (49-year timeline), argument mapping (5 objections, 5 rebuttals), comparative treaty analysis (ICCPR precedent, 173-nation comparison). Sources: Senate Foreign Relations Committee records, OHCHR treaty body database, constitutional scholarship.",
};

const cardStats: Record<string, { number: string; label: string }> = {
  'timeline': { number: '49', label: 'Years' },
  'arguments': { number: '5', label: 'Core Objections' },
  'counterarguments': { number: '5', label: 'Rebuttals' },
  'not-really-rights': { number: '3', label: 'Misconceptions' },
  'comparison': { number: '173', label: 'Ratifying Nations' },
};
---

<SectionLayout
  title="The Gap"
  description="The United States signed the ICESCR in 1977. Nearly five decades later, the Senate has never voted on ratification. This section examines why — and what that gap costs."
  section="gap"
>
  <LensPanel lensFraming={lensFraming} section="gap" />

  <div class="gap-grid">
    {sorted.map((page) => (
      <a href={`/gap/${page.id}`} class="gap-card">
        {cardStats[page.id] && (
          <span class="card-visual card-visual--stat">
            <span class="visual-number">{cardStats[page.id].number}</span>
            <span class="visual-label">{cardStats[page.id].label}</span>
          </span>
        )}
        <h2>{page.data.title}</h2>
        <p>{page.data.summary}</p>
      </a>
    ))}
  </div>

  <section class="gap-summary">
    <h2>The Pattern</h2>
    <p>
      Across 12 presidential terms and 49 years, no administration prioritized <a href="https://www.ohchr.org/en/instruments-mechanisms/instruments/international-covenant-economic-social-and-cultural-rights" rel="noopener">ICESCR</a> ratification.
      Not because the arguments against it prevailed in debate — the debate never occurred.
      The ICESCR remains unratified because no one with political power found ratification worth the effort.
    </p>
    <p>
      AI-driven economic transformation changes the calculation. When technology restructures
      the labor market faster than any previous force, the absence of enforceable economic rights
      protections shifts from philosophical debate to observable consequence.
    </p>
    <p>
      <a href="/connection">Explore the AI connection &rarr;</a>
    </p>
  </section>

  <section class="cross-section-nav">
    <h2>What Ratification Would Change</h2>
    <p>
      The <a href="/connection/ratification-counterfactual">ratification counterfactual</a> models
      what happens when the gap closes — using the <a href="/glossary#ada-pattern">ADA pattern</a>
      to predict enforcement timelines, <a href="/glossary#quality-floor">quality floors</a> for AI
      in rights-critical domains, and <a href="/glossary#state-ag-litigation">State AG litigation</a>
      as the dominant enforcement mechanism.
    </p>
    <p>
      What these rights protect: <a href="/covenant">The Covenant</a> |
      The data behind the analysis: <a href="/evidence">Evidence</a> |
      <a href="/glossary">Glossary of terms</a>
    </p>
  </section>

  <section class="observatory-callout">
    <h2>Live Evidence</h2>
    <p>
      The <a href="https://observatory.unratified.org/factions" rel="noopener">Human Rights Observatory</a>
      clusters news sources by editorial character across {obs.corpusSize.toLocaleString()}+ evaluated
      stories — revealing how different outlets frame the very rights this gap leaves unprotected.
    </p>
  </section>
</SectionLayout>

<style>
  .gap-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
  }

  .gap-card {
    display: block;
    padding: var(--space-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.15s;
  }

  .gap-card:hover {
    border-color: var(--color-accent);
  }

  .gap-card h2 {
    font-size: 1.1rem;
    margin-top: 0;
    margin-bottom: var(--space-sm);
  }

  .gap-card p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .gap-summary {
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .cross-section-nav {
    padding: var(--space-lg);
    background: var(--color-surface-alt);
    border-left: 3px solid var(--color-accent);
    border-radius: 0 4px 4px 0;
    margin-bottom: var(--space-2xl);
  }

  .cross-section-nav h2 {
    margin-top: 0;
    font-size: 1.1rem;
  }

  .cross-section-nav p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .cross-section-nav a {
    font-weight: 500;
  }
</style>
