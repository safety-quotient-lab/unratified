---
import ArticleLayout from '../../../layouts/ArticleLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  // ICESCR article number → corresponding UDHR article for Observatory deep-linking
  // Defined inside getStaticPaths — Astro extracts this function to a separate build context
  const UDHR_MAP: Record<number, { article: number; title: string }> = {
    6:  { article: 23, title: 'Work & Equal Pay' },
    7:  { article: 23, title: 'Work & Equal Pay' },
    9:  { article: 22, title: 'Social Security' },
    10: { article: 16, title: 'Marriage & Family' },
    11: { article: 25, title: 'Standard of Living' },
    12: { article: 25, title: 'Standard of Living' },
    13: { article: 26, title: 'Education' },
    14: { article: 26, title: 'Education' },
    15: { article: 27, title: 'Cultural Participation' },
  };

  const articles = await getCollection('covenant');
  const sorted = articles.sort((a, b) => a.data.order - b.data.order);

  return sorted.map((article, index) => {
    const prev = index > 0 ? sorted[index - 1] : undefined;
    const next = index < sorted.length - 1 ? sorted[index + 1] : undefined;
    const udhr = UDHR_MAP[article.data.articleNumber];

    return {
      params: { slug: article.id },
      props: {
        article,
        udhrArticle: udhr?.article,
        udhrTitle: udhr?.title,
        prevArticle: prev
          ? { number: prev.data.articleNumber, slug: prev.id, rightName: prev.data.rightName }
          : undefined,
        nextArticle: next
          ? { number: next.data.articleNumber, slug: next.id, rightName: next.data.rightName }
          : undefined,
      },
    };
  });
}

const { article, udhrArticle, udhrTitle, prevArticle, nextArticle } = Astro.props;
const { Content, headings } = await render(article);
---

<ArticleLayout
  title={article.data.title}
  articleNumber={article.data.articleNumber}
  rightName={article.data.rightName}
  summary={article.data.summary}
  aiConnection={article.data.aiConnection}
  legalText={article.data.legalText}
  pivotal={article.data.pivotal}
  udhrArticle={udhrArticle}
  udhrTitle={udhrTitle}
  prevArticle={prevArticle}
  nextArticle={nextArticle}
  headings={headings}
>
  <Content />
</ArticleLayout>
