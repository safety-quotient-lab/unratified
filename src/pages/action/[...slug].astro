---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LensPanel from '../../components/LensPanel.astro';
import SharePrompt from '../../components/ui/SharePrompt.astro';
import TableOfContents from '../../components/ui/TableOfContents.svelte';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const pages = await getCollection('action');
  return pages.map((page) => ({
    params: { slug: page.id },
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content, headings } = await render(page);
const pageUrl = `https://unratified.org/action/${page.id}`;
---

<BaseLayout title={page.data.title} description={page.data.summary}>
  <article class="action-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/action">Take Action</a></li>
        <li aria-current="page">{page.data.title}</li>
      </ol>
    </nav>

    <header>
      <h1>{page.data.title}</h1>
      <p class="lede">{page.data.summary}</p>
    </header>

    <LensPanel lensFraming={page.data.lensFraming} section="action" />

    <TableOfContents headings={headings} client:load />

    <div class="content">
      <Content />
    </div>

    <SharePrompt shareUrl={pageUrl} />

    <nav class="section-nav">
      <a href="/action">&larr; Back to Take Action</a>
    </nav>
  </article>
</BaseLayout>

<style>
  .action-page {
    max-width: var(--max-width-content);
    margin: 0 auto;
  }

  .breadcrumb ol {
    list-style: none;
    display: flex;
    gap: var(--space-sm);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
  }

  .breadcrumb li + li::before {
    content: '/';
    margin-right: var(--space-sm);
    color: var(--color-border);
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .lede {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 36rem;
  }

  .content {
    margin-top: var(--space-xl);
  }

  .content :global(ul),
  .content :global(ol) {
    margin: var(--space-md) 0 var(--space-md) var(--space-xl);
  }

  .content :global(li) {
    margin-bottom: var(--space-sm);
  }

  .section-nav {
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .section-nav a {
    font-family: var(--font-heading);
    font-size: 0.875rem;
  }
</style>
