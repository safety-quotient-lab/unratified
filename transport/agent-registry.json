{
  "schema": "agent-registry/v1",
  "description": "Known agents in the unratified-agent mesh. /sync reads this to determine who to check for activity.",
  "updated": "2026-03-10",

  "agents": {
    "psychology-agent": {
      "role": "peer",
      "description": "Psychology agent — orchestrator, collegial mentor, cogarch host",
      "transport": "cross-repo-fetch",
      "repo": "safety-quotient-lab/psychology-agent",
      "remote_name": "psychology-agent",
      "sessions_path": "transport/sessions/",
      "manifest_path": "transport/MANIFEST.json",
      "message_prefix": "from-psychology-agent-",
      "active_sessions": ["blog-publication", "content-quality-loop", "psq-scoring", "site-defensibility-review"],
      "always_consider": true,
      "autonomous": false,
      "discovery_url": "https://psychology-agent.safety-quotient.dev/.well-known/agent-card.json",
      "notes": "Primary peer. Cross-repo transport via git remote fetch."
    },
    "observatory-agent": {
      "role": "peer",
      "description": "Data observatory — methodology validation, ICESCR framing",
      "transport": "cross-repo-fetch",
      "repo": "safety-quotient-lab/observatory",
      "remote_name": "observatory",
      "sessions_path": "transport/sessions/",
      "message_prefix": "from-observatory-agent-",
      "active_sessions": ["activitypub-federation", "icescr-framing", "observatory-methodology", "state-feedback-exchange"],
      "always_consider": false,
      "autonomous": false,
      "discovery_url": "https://observatory.unratified.org/.well-known/agent-card.json",
      "notes": "Peer agent. Shared sessions for methodology and data exchange."
    },
    "psq-agent": {
      "role": "peer",
      "description": "Safety-quotient agent — PSQ scoring, psychometric model",
      "transport": "cross-repo-fetch",
      "repo": "safety-quotient-lab/safety-quotient",
      "remote_name": "safety-quotient",
      "sessions_path": "transport/sessions/",
      "manifest_path": "transport/MANIFEST.json",
      "message_prefix": "from-psq-sub-agent-",
      "active_sessions": ["psq-scoring"],
      "always_consider": false,
      "autonomous": false,
      "discovery_url": "https://psq.safety-quotient.dev/.well-known/agent-card.json",
      "notes": "PSQ scoring peer. Shared psq-scoring session."
    }
  },

  "outbound_routing": {
    "description": "Content routing rules for outbound message drafting.",
    "rules": [
      {
        "domain": "content-quality",
        "keywords": ["blog", "content", "publication", "fair witness", "vocabulary drift"],
        "route_to": ["psychology-agent"],
        "action": "notify psychology-agent of content changes"
      },
      {
        "domain": "methodology",
        "keywords": ["ICESCR", "methodology", "data collection", "measurement"],
        "route_to": ["observatory-agent"],
        "action": "flag for review"
      }
    ]
  }
}
